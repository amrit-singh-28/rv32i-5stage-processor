   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="140"></NameColumnWidth>
      <ValueColumnWidth column_width="178"></ValueColumnWidth>
   </column_width_setting>
   <WVObjectSize size="10" />
   <wvobject fp_name="/register_tb/clk" type="logic">
